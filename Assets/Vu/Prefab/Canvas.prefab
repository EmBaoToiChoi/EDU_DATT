  questionDataList:
  - questionText: "L\u1EDBp 1: 5 + 4 b\u1EB1ng bao nhi\xEAu?"
    answerA: 7
    answerB: 8
    answerC: 9
    answerD: 10
    correctAnswer: C
  - questionText: "L\u1EDBp 1: H\xECnh n\xE0o sau \u0111\xE2y c\xF3 3 c\u1EA1nh?"
    answerA: "H\xECnh vu\xF4ng"
    answerB: "H\xECnh tam gi\xE1c"
    answerC: "H\xECnh tr\xF2n"
    answerD: "H\xECnh ch\u1EEF nh\u1EADt"
    correctAnswer: B
  - questionText: "L\u1EDBp 2: 5 x 4 b\u1EB1ng bao nhi\xEAu?"
    answerA: 20
    answerB: 25
    answerC: 15
    answerD: 30
    correctAnswer: A
  - questionText: "L\u1EDBp 2: S\u1ED1 li\u1EC1n sau c\u1EE7a s\u1ED1 99 l\xE0 s\u1ED1
      n\xE0o?"
    answerA: 98
    answerB: 100
    answerC: 101
    answerD: 90
    correctAnswer: B
  - questionText: "L\u1EDBp 3: S\u1ED1 g\u1ED3m 3 ngh\xECn, 5 tr\u0103m v\xE0 2 \u0111\u01A1n
      v\u1ECB vi\u1EBFt l\xE0:"
    answerA: 352
    answerB: 3520
    answerC: 3052
    answerD: 3502
    correctAnswer: D
  - questionText: "L\u1EDBp 3: M\u1ED9t h\xECnh vu\xF4ng c\xF3 c\u1EA1nh 5cm. Chu
      vi h\xECnh vu\xF4ng \u0111\xF3 l\xE0?"
    answerA: 20cm
    answerB: 25cm
    answerC: 15cm
    answerD: 10cm
    correctAnswer: A
  - questionText: "L\u1EDBp 2: C\xF3 14 qu\u1EA3 t\xE1o chia \u0111\u1EC1u cho 2
      b\u1EA1n. M\u1ED7i b\u1EA1n \u0111\u01B0\u1EE3c m\u1EA5y qu\u1EA3?"
    answerA: "6 qu\u1EA3"
    answerB: "7 qu\u1EA3"
    answerC: "8 qu\u1EA3"
    answerD: "9 qu\u1EA3"
    correctAnswer: B
  - questionText: "L\u1EDBp 3: Th\xE1ng n\xE0o sau \u0111\xE2y lu\xF4n c\xF3 28 ho\u1EB7c
      29 ng\xE0y?"
    answerA: "Th\xE1ng 1"
    answerB: "Th\xE1ng 2"
    answerC: "Th\xE1ng 3"
    answerD: "Th\xE1ng 12"
    correctAnswer: B
